{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=your-server.postgres.database.azure.com;Port=5432;Database=sincopos;Username=your-user;Password=your-password;Ssl Mode=Require;Trust Server Certificate=true"
  },
  "Authentication": {
    "Authority": "http://localhost:8080/realms/sincopos",
    "Audience": "pos-api",
    "RequireHttpsMetadata": false,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true
  }
}