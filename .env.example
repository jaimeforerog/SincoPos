# Configuración de base de datos PostgreSQL
POSTGRES_DB=sincopos
POSTGRES_USER=posuser
POSTGRES_PASSWORD=pospass123

# Configuración de Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_DB_PASSWORD=keycloak123

# Configuración de la API
ASPNETCORE_ENVIRONMENT=Development
JWT_AUTHORITY=http://localhost:8080/realms/sincopos
JWT_AUDIENCE=pos-api
JWT_REQUIRE_HTTPS=false

# Connection Strings
ConnectionStrings__DefaultConnection=Host=localhost;Database=sincopos;Username=posuser;Password=pospass123
ConnectionStrings__MartenConnection=Host=localhost;Database=sincopos;Username=posuser;Password=pospass123
